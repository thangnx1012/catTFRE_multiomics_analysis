```{r} 
COND_COLOURS <- c(NE = "#377EB8", C4 = "#1B9E77", C1 = "#A020F0") #1B9E77 #D73027 #377EB8 # 2CA25F
DET_THR      <- 1   # raw count threshold for "detected" (≥ DET_THR)

count_detected <- function(accessions = NULL) {
  d <- counts_raw %>%
    select(Accession, all_of(sample_cols))
  if (!is.null(accessions))
    d <- d %>% filter(Accession %in% accessions)

  d %>%
    pivot_longer(all_of(sample_cols),
                 names_to = "sample", values_to = "count") %>%
    separate(sample, c("cell_line","condition","rep"),
             sep = "_", remove = FALSE) %>%
    mutate(rep        = as.integer(str_remove(rep, "rep")),
           cell_line  = factor(cell_line, levels = CELL_LINES),
           condition  = factor(condition, levels = CONDITIONS)) %>%
    group_by(cell_line, condition, rep) %>%
    summarise(n_detected = sum(count >= DET_THR), .groups = "drop")
}
# Count the detect protein
det_all <- count_detected() # all proteins
det_tf  <- count_detected(tf_flag %>% filter(IsTF) %>% pull(Accession))

# Plot the counts
plot_overview <- function(d, title) {
  smy <- d %>%
    group_by(cell_line, condition) %>%
    summarise(mean = mean(n_detected),
              sd   = sd(n_detected), .groups = "drop") 
  # Order cell lines
  smy$cell_line <- factor(smy$cell_line,levels = c("MG63", "U2OS", "HOS"))
  d$cell_line <- factor(d$cell_line,levels = c("MG63", "U2OS", "HOS"))
  # Plot
  ggplot(smy, aes(cell_line, mean, color = condition)) +
    geom_col(position = position_dodge(0.78),width = 0.72,fill = "white",linewidth = 0.7) +
    geom_errorbar(aes(ymin = mean - sd,ymax = mean + sd),position = position_dodge(0.78),width = 0.18,linewidth = 0.5) +
    geom_jitter(data = d,
                aes(y = n_detected,group = condition,color = condition),
                position = position_jitterdodge(jitter.width = 0.12,dodge.width = 0.78,seed = 1),
                size = 1.8,alpha = 0.9,inherit.aes = TRUE) +
    geom_text(aes(label = round(mean, 0),y = mean + sd + max(smy$mean) * 0.1),position = position_dodge(0.78),size = 2.6) +
    scale_color_manual(values = COND_COLOURS,name = "Condition") +
    labs(title = title,x = NULL,y = sprintf("# detected proteins (count ≥ %d)", DET_THR)) +
    coord_flip() +
    theme_classic(base_size = 10) +
    theme(plot.title = element_text(face = "bold"),
          axis.text.y = element_text(face = "bold", size = 10),
          legend.position = "right")
}

