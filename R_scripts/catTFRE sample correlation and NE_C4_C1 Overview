## Plot — reusable function

```{r alluvial_fn}
DIR_COLOURS <- c(
  "C1 > NE (gained)"    = "#d62728",
  "C1 = NE (no change)" = "#bdbdbd",
  "C1 < NE (lost)"      = "#1f77b4")

plot_alluvial_one <- function(cl, flows, smy, label = "") {
  d   <- flows %>% dplyr::filter(cell_line == cl)
  rs  <- smy   %>% dplyr::filter(cell_line == cl)
  n_g <- if (!is.null(rs$`C1 > NE (gained)`))    rs$`C1 > NE (gained)`    else 0L
  n_s <- if (!is.null(rs$`C1 = NE (no change)`)) rs$`C1 = NE (no change)` else 0L
  n_l <- if (!is.null(rs$`C1 < NE (lost)`))      rs$`C1 < NE (lost)`      else 0L

  ggplot(d, aes(axis1 = NE, axis2 = C4, axis3 = C1, y = n_proteins)) +
    geom_alluvium(aes(fill = direction), alpha = 0.80,
                  width = 0.18, knot.pos = 0.40,
                  color = "white", linewidth = 0.30) +
    geom_stratum(width = 0.18, fill = "grey92",
                 color = "grey40", linewidth = 0.40) +
    geom_text(stat = "stratum",
              aes(label = sprintf("%s\n(%d)",
                                  after_stat(stratum),
                                  after_stat(count))),
              size = 2.5, lineheight = 0.85) +
    scale_x_discrete(limits = c("NE","C4","C1"),
                     expand = c(0.08, 0.08)) +
    scale_fill_manual(values = DIR_COLOURS,
                      breaks = names(DIR_COLOURS), name = NULL) +
    labs(title    = sprintf("%s — %s", cl, label),
         subtitle = sprintf("%s gained · %s unchanged · %s lost  (n = %s)",
                            format(n_g, big.mark = ","),
                            format(n_s, big.mark = ","),
                            format(n_l, big.mark = ","),
                            format(sum(d$n_proteins), big.mark = ",")),
         x = NULL, y = NULL) +
    theme_classic(base_size = 10) +
    theme(axis.line.y     = element_blank(),
          axis.ticks.y    = element_blank(),
          axis.text.y     = element_blank(),
          axis.text.x     = element_text(face = "bold", size = 9),
          plot.title      = element_text(face = "bold", size = 11),
          plot.subtitle   = element_text(size  = 8.5, color = "grey25"))
}

build_alluvial_grid <- function(flows, smy, label, top_title) {
  panels <- map(CELL_LINES,
                ~ plot_alluvial_one(.x, flows, smy, label = label))
  wrap_plots(panels, nrow = 1) +
    plot_layout(guides = "collect") +
    plot_annotation(
      title = top_title,
      theme = theme(plot.title = element_text(face = "bold", size = 12))) &
    theme(legend.position = "bottom",
          legend.text     = element_text(size = 9))
}
