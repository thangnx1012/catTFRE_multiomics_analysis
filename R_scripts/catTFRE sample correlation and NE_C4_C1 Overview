```{r eod_lod_4set_helpers}
# Detection sets per cell × scope × filter
detect_set <- function(cl, scope, tf_only) {
  cols <- if (scope == "pull") {
    c(paste0(cl, "_C1_rep", 1:4), paste0(cl, "_C4_rep", 1:4))
  } else {
    paste0(cl, "_NE_rep", 1:4)
  }
  m  <- rowMeans(counts_raw[, cols, drop = FALSE])
  gs <- toupper(str_trim(counts_raw$Gene_Symbol))
  keep <- m >= DET_THR
  if (tf_only) keep <- keep & gs %in% tf_universe
  unique(gs[keep])
}

# 4-set Venn for one (list, scope, filter) combination
# NB: tf_only ONLY filters the cell-line detection sets.  EOD / LOD stay
# at their original size (162 / 155) regardless of `tf_only`.
plot_venn4 <- function(list_name, list_genes, scope, tf_only) {
  v <- list()
  v[[sprintf("%s\n(n=%d)", list_name, length(list_genes))]] <- list_genes
  for (cl in CELL_LINES) {
    d <- detect_set(cl, scope, tf_only)
    v[[sprintf("%s\n(n=%d)", cl, length(d))]] <- d
  }
  scope_lab  <- if (scope == "pull") "C1+C4 (8 reps)" else "NE only (4 reps)"
  filter_lab <- if (tf_only) "Cells: TF-filtered (Cell 2018)" else "Cells: no filter"
  ggVennDiagram(v, label_alpha = 0, label = "count",
                edge_size = 0.4, set_size = 3) +
    scale_fill_gradient(low = "#f0f9ff", high = "darkgreen") + # orange
    labs(title = sprintf("%s — %s", filter_lab, scope_lab)) +
    theme(plot.title       = element_text(face = "bold", size = 10),
          legend.position  = "none")
}
