```{r eod_lod_detection}
# Detection sets per cell-line × scope, FILTERED TO TFs (Cell 2018 universe).
DET_THR <- 1
detect_TF_set <- function(cl, scope) {
  cols <- if (scope == "pull") {
    c(paste0(cl, "_C1_rep", 1:4), paste0(cl, "_C4_rep", 1:4))
  } else {
    paste0(cl, "_NE_rep", 1:4)
  }
  m <- rowMeans(counts_raw[, cols, drop = FALSE])
  gs <- toupper(str_trim(counts_raw$Gene_Symbol))
  unique(gs[m >= DET_THR & gs %in% tf_universe])
}

sets <- list(HOS_pull  = detect_TF_set("HOS",  "pull"),
             MG63_pull = detect_TF_set("MG63", "pull"),
             U2OS_pull = detect_TF_set("U2OS", "pull"),
             HOS_NE    = detect_TF_set("HOS",  "NE"),
             MG63_NE   = detect_TF_set("MG63", "NE"),
             U2OS_NE   = detect_TF_set("U2OS", "NE"))

cat("TFs detected per cell-line × scope:\n"); print(sapply(sets, length))
