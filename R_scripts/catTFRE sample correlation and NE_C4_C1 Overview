make_flows <- function(bw) {
  bw %>%
    dplyr::count(cell_line, NE, C4, C1, name = "n_proteins") %>%
    mutate(NE = factor(NE, levels = BIN_LAB),
           C4 = factor(C4, levels = BIN_LAB),
           C1 = factor(C1, levels = BIN_LAB),
           direction = case_when(
             as.integer(C1) > as.integer(NE) ~ "C1 > NE (gained)",
             as.integer(C1) < as.integer(NE) ~ "C1 < NE (lost)",
             TRUE                            ~ "C1 = NE (no change)"))
}

make_summary <- function(flows) {
  flows %>%
    group_by(cell_line, direction) %>%
    summarise(n = sum(n_proteins), .groups = "drop") %>%
    pivot_wider(names_from = direction, values_from = n, values_fill = 0)
}

