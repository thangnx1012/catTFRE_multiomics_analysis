```{r binning}
assign_bin <- function(x) {
  out <- cut(x, breaks = c(-Inf, 1, 20, 50, Inf),
             labels = BIN_LAB, right = FALSE)
  factor(as.character(out), levels = BIN_LAB)
}

# Reusable: build a wide bin table for a given subset of Accessions.
build_bins_wide <- function(accessions = NULL) {
  d <- counts_raw %>%
    dplyr::select(Accession, Gene_Symbol, all_of(sample_cols))
  if (!is.null(accessions))
    d <- d %>% dplyr::filter(Accession %in% accessions)

  d %>%
    pivot_longer(all_of(sample_cols), names_to = "sample", values_to = "count") %>%
    separate(sample, c("cell_line","condition","rep"), sep = "_", remove = FALSE) %>%
    mutate(rep = as.integer(str_remove(rep, "rep"))) %>%
    group_by(Accession, Gene_Symbol, cell_line, condition) %>%
    summarise(mean_count = mean(count), .groups = "drop") %>%
    mutate(bin = assign_bin(mean_count)) %>%
    dplyr::select(-mean_count) %>%
    pivot_wider(names_from = condition, values_from = bin) %>%
    mutate(cell_line = factor(cell_line, levels = CELL_LINES))
}

