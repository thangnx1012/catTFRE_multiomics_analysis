```{r}
# Per (cell, condition) TF detection at the GENE-SYMBOL level (not per-rep counts)
tf_long_mean <- counts_raw %>%
  inner_join(tf_flag %>% filter(IsTF) %>% select(Accession), by = "Accession") %>%
  pivot_longer(all_of(sample_cols), names_to = "sample", values_to = "count") %>%
  separate(sample, c("cell_line","condition","rep"), sep = "_", remove = FALSE) %>%
  mutate(rep = as.integer(str_remove(rep, "rep"))) %>%
  group_by(Accession, Gene_Symbol, cell_line, condition) %>%
  summarise(mean_count = mean(count), .groups = "drop") %>%
  mutate(detected = mean_count >= DET_THR,
         gs = toupper(str_trim(Gene_Symbol)))

# Build named list of vectors
sets_cc <- list()
for (cd in c("C1","C4","NE")) {
  for (cl in c("HOS","MG63","U2OS")) {
    sets_cc[[paste0(cd,"_",cl)]] <- tf_long_mean %>%
      filter(condition == cd, cell_line == cl, detected) %>%
      pull(gs) %>% unique() %>% sort()
  }
}
# overlap between conditions
inter_per_cond <- list()
for (cd in c("C1","C4","NE")) {
  inter_per_cond[[paste0(cd,"_all3cells")]] <-
    Reduce(intersect, list(sets_cc[[paste0(cd,"_HOS")]],
                           sets_cc[[paste0(cd,"_MG63")]],
                           sets_cc[[paste0(cd,"_U2OS")]])) %>% sort()
}
core <- Reduce(intersect, inter_per_cond) %>% sort()
# Detected in all conditions
union_per_cond <- list()
for (cd in c("C1","C4","NE")) {
  union_per_cond[[paste0(cd,"_any_of_3cells")]] <-
    Reduce(union, list(sets_cc[[paste0(cd,"_HOS")]],
                       sets_cc[[paste0(cd,"_MG63")]],
                       sets_cc[[paste0(cd,"_U2OS")]])) %>% sort()
}

groups <- c(sets_cc, union_per_cond, inter_per_cond,
            list(allConditions_allCells   = core,
                 C1only_in_all3cells      = sort(setdiff(inter_per_cond$C1_all3cells,
                                                         union(inter_per_cond$C4_all3cells,
                                                               inter_per_cond$NE_all3cells))),
                 C1andC4only_in_all3cells = sort(setdiff(intersect(inter_per_cond$C1_all3cells,
                                                                    inter_per_cond$C4_all3cells),
                                                         inter_per_cond$NE_all3cells)),
                 C4only_in_all3cells      = sort(setdiff(inter_per_cond$C4_all3cells,
                                                         union(inter_per_cond$C1_all3cells,
                                                               inter_per_cond$NE_all3cells))),
                 NEonly_in_all3cells      = sort(setdiff(inter_per_cond$NE_all3cells,
                                                         union(inter_per_cond$C1_all3cells,
                                                               inter_per_cond$C4_all3cells)))))

# Pad each vector to max length so they line up as columns
nmax <- max(lengths(groups))
merged <- as.data.frame(lapply(groups, function(v) c(v, rep("", nmax - length(v)))),
                        stringsAsFactors = FALSE, check.names = FALSE)
# Counts row at the top
counts_row <- as.data.frame(lapply(groups, function(v) sprintf("n=%d", length(v))),
                            stringsAsFactors = FALSE, check.names = FALSE)
merged <- rbind(counts_row, merged)

wb <- createWorkbook()
addWorksheet(wb, "TF_detection_lists")
hdr <- createStyle(fontColour = "white", fgFill = "#1F4E78",
                   textDecoration = "bold")
writeData(wb, "TF_detection_lists", merged, headerStyle = hdr)
freezePane(wb, "TF_detection_lists", firstRow = TRUE, firstActiveRow = 3)
setColWidths(wb, "TF_detection_lists", 1:ncol(merged), 18)
saveWorkbook(wb,file.path(plots_dir, "TFs_detected_per_condition_merged.xlsx"),overwrite = TRUE)
