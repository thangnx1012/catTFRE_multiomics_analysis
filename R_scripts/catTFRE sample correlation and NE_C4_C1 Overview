# Per-cell-line sample correlation

```{r}
log2_mat <- counts_raw %>%
  dplyr::select(Accession, all_of(sample_cols)) %>%
  column_to_rownames("Accession") %>%
  as.matrix() %>%
  { log2(. + 1) }

# Plot function
plot_cor_heatmap <- function(cl) {
  cols <- grep(paste0("^", cl, "_"), colnames(log2_mat), value = TRUE)
  cm   <- cor(log2_mat[, cols], method = "pearson")
  cm_df <- as.data.frame(cm) %>%
    rownames_to_column("s1") %>%
    pivot_longer(-s1, names_to = "s2", values_to = "r") %>%
    mutate(s1 = factor(s1, levels = cols),
           s2 = factor(s2, levels = cols))
  # Plot
  ggplot(cm_df, aes(s1, s2, fill = r)) +
    geom_tile(color = "white", linewidth = 0.2) +
    geom_text(aes(label = sprintf("%.2f", r)), size = 2) +
    scale_fill_gradientn(colours = c("#2166ac","#f7f7f7","#D73027"),
                         limits = c(0.5, 1), oob = scales::squish,
                         name = "Pearson r") +
    labs(title = sprintf("%s — catTFRE C1/C4/NE correlation", cl),
         x = NULL, y = NULL) +
    coord_fixed() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1, size = 7),
          axis.text.y = element_text(size = 7),
          legend.position = "top",
          legend.direction = "horizontal")
}

