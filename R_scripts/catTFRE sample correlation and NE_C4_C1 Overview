# Comprehensive workbook: every (list × scope × filter) combo.
#   - Summary sheet: counts per region across all 8 combos
#   - One sheet per combo with the genes in the central intersection
#     (list ∩ HOS ∩ MG63 ∩ U2OS) and the genes that are list-only
#     (in the gene list but detected in zero cell lines).
build_combo <- function(list_name, list_genes, scope, tf_only) {
  # tf_only only filters the cell-line detection sets — EOD/LOD always full size
  gset <- list_genes
  H <- detect_set("HOS",  scope, tf_only)
  M <- detect_set("MG63", scope, tf_only)
  U <- detect_set("U2OS", scope, tf_only)
  in_all3      <- Reduce(intersect, list(gset, H, M, U))
  list_only    <- setdiff(gset, union(H, union(M, U)))
  tibble(list = list_name,
         scope  = if (scope == "pull") "C1+C4 (8 reps)" else "NE only (4 reps)",
         filter = if (tf_only) "Cells: TFs only" else "Cells: no filter",
         n_list      = length(gset),
         n_HOS       = length(H),
         n_MG63      = length(M),
         n_U2OS      = length(U),
         n_all3      = length(Reduce(intersect, list(H, M, U))),
         n_in_all3   = length(in_all3),
         n_list_only = length(list_only),
         genes_in_all3   = list(sort(in_all3)),
         genes_list_only = list(sort(list_only)))
}

